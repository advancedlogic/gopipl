# Built binaries
/bin/

# Local peer state: identity private keys, group keys, and the per-object
# signing keys that ARE the revocation authority. Never commit these.
# `pipl -home ./peers/alice` and friends land here.
/peers/
/server/
.pipl/
*.pipl-home/

# Conversation folders, if created inside the repo while testing: these
# hold encrypted objects and sealed grants.
/shared/

# The Wails desktop client has its own desktop/.gitignore for build output,
# node_modules, and generated bindings.
